{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/whyiug/pii-detect-model/schemas/community_v2_github_release_assets_receipt.schema.json",
  "title": "Community v2 GitHub Release asset verification receipt",
  "description": "Closed, offline receipt for the exact 0.2.0rc1 wheel, CycloneDX SBOM, and two-line checksum closure. PASS states are produced by local verification rather than accepted from callers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_commit",
    "release",
    "source",
    "assets",
    "checksum_closure",
    "wheel_inventory",
    "sbom_verification",
    "isolated_wheel_smoke",
    "public_artifact_scan",
    "implementation",
    "receipt_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": "pii-zh.community-v2-github-release-assets-receipt.v1"
    },
    "source_commit": { "$ref": "#/$defs/gitCommit" },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_name",
        "package_version",
        "tag_name",
        "github_repository",
        "asset_count",
        "asset_names"
      ],
      "properties": {
        "package_name": { "const": "pii-zh-qwen" },
        "package_version": { "const": "0.2.0rc1" },
        "tag_name": { "const": "v0.2.0rc1" },
        "github_repository": { "const": "whyiug/pii-detect-model" },
        "asset_count": { "const": 3 },
        "asset_names": {
          "const": [
            "pii_zh_qwen-0.2.0rc1-py3-none-any.whl",
            "sbom.cdx.json",
            "checksums.txt"
          ]
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_source_commit",
        "repository_head_verified",
        "implementation_files_match_commit",
        "binding_scope"
      ],
      "properties": {
        "git_source_commit": { "$ref": "#/$defs/gitCommit" },
        "repository_head_verified": { "const": true },
        "implementation_files_match_commit": { "const": true },
        "binding_scope": {
          "const": "verification_execution_context_at_exact_head_not_reproducible_wheel_build"
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wheel", "sbom", "checksums"],
      "properties": {
        "wheel": {
          "allOf": [
            { "$ref": "#/$defs/namedFileBinding" },
            {
              "properties": {
                "name": { "const": "pii_zh_qwen-0.2.0rc1-py3-none-any.whl" },
                "media_type": { "const": "application/zip" }
              }
            }
          ]
        },
        "sbom": {
          "allOf": [
            { "$ref": "#/$defs/namedFileBinding" },
            {
              "properties": {
                "name": { "const": "sbom.cdx.json" },
                "media_type": { "const": "application/vnd.cyclonedx+json" }
              }
            }
          ]
        },
        "checksums": {
          "allOf": [
            { "$ref": "#/$defs/namedFileBinding" },
            {
              "properties": {
                "name": { "const": "checksums.txt" },
                "media_type": { "const": "text/plain; charset=utf-8" }
              }
            }
          ]
        }
      }
    },
    "checksum_closure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "format",
        "line_count",
        "ordered_entries",
        "exact_payload_asset_set",
        "declared_digests_match_assets",
        "self_entry_absent",
        "single_asset_directory_verified"
      ],
      "properties": {
        "status": { "const": "PASS" },
        "format": { "const": "sha256sum_two_space_lf_v1" },
        "line_count": { "const": 2 },
        "ordered_entries": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "file_sha256"],
              "properties": {
                "name": { "const": "pii_zh_qwen-0.2.0rc1-py3-none-any.whl" },
                "file_sha256": { "$ref": "#/$defs/sha256" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "file_sha256"],
              "properties": {
                "name": { "const": "sbom.cdx.json" },
                "file_sha256": { "$ref": "#/$defs/sha256" }
              }
            }
          ],
          "items": false
        },
        "exact_payload_asset_set": { "const": true },
        "declared_digests_match_assets": { "const": true },
        "self_entry_absent": { "const": true },
        "single_asset_directory_verified": { "const": true }
      }
    },
    "wheel_inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "format",
        "distribution_name",
        "distribution_version",
        "member_count",
        "member_inventory_sha256",
        "members",
        "required_member_ids",
        "required_members_present",
        "inventory_implementation_path",
        "inventory_implementation_file_sha256"
      ],
      "properties": {
        "status": { "const": "PASS" },
        "format": { "const": "python_wheel_zip_v1" },
        "distribution_name": { "const": "pii-zh-qwen" },
        "distribution_version": { "const": "0.2.0rc1" },
        "member_count": { "type": "integer", "minimum": 1 },
        "member_inventory_sha256": { "$ref": "#/$defs/sha256" },
        "members": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:@+-]{0,191}$"
          },
          "additionalProperties": { "$ref": "#/$defs/memberBinding" }
        },
        "required_member_ids": {
          "const": [
            "pii_zh:cli.py",
            "pii_zh:service:app.py",
            "pii_zh:cascade:routing.py",
            "pii_zh:taxonomy:taxonomy.yaml"
          ]
        },
        "required_members_present": { "const": true },
        "inventory_implementation_path": {
          "const": "scripts/produce_community_cascade_release_v2_artifacts.py"
        },
        "inventory_implementation_file_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "sbom_verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "format",
        "bom_sha256",
        "component_count",
        "dependency_edge_count",
        "deterministic_source_regeneration_match",
        "lockfile_file_sha256",
        "pyproject_file_sha256",
        "generator_path",
        "generator_file_sha256"
      ],
      "properties": {
        "status": { "const": "PASS" },
        "format": { "const": "CycloneDX-1.6" },
        "bom_sha256": { "$ref": "#/$defs/sha256" },
        "component_count": { "type": "integer", "minimum": 1 },
        "dependency_edge_count": { "type": "integer", "minimum": 0 },
        "deterministic_source_regeneration_match": { "const": true },
        "lockfile_file_sha256": { "$ref": "#/$defs/sha256" },
        "pyproject_file_sha256": { "$ref": "#/$defs/sha256" },
        "generator_path": { "const": "scripts/generate_sbom.py" },
        "generator_file_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "isolated_wheel_smoke": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "profile_version",
        "harness_path",
        "harness_file_sha256",
        "harness_result_sha256",
        "stdout_sha256",
        "stderr_sha256",
        "stderr_empty",
        "runtime_versions",
        "assertions",
        "isolation"
      ],
      "properties": {
        "status": { "const": "PASS" },
        "profile_version": { "const": "c1-conservative-v2" },
        "harness_path": { "const": "scripts/run_successor_clean_wheel_smoke.py" },
        "harness_file_sha256": { "$ref": "#/$defs/sha256" },
        "harness_result_sha256": { "$ref": "#/$defs/sha256" },
        "stdout_sha256": { "$ref": "#/$defs/sha256" },
        "stderr_sha256": { "$ref": "#/$defs/sha256" },
        "stderr_empty": { "const": true },
        "runtime_versions": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "python",
            "pii-zh-qwen",
            "presidio-analyzer",
            "fastapi",
            "httpx"
          ],
          "properties": {
            "python": { "$ref": "#/$defs/versionString" },
            "pii-zh-qwen": { "const": "0.2.0rc1" },
            "presidio-analyzer": { "$ref": "#/$defs/versionString" },
            "fastapi": { "$ref": "#/$defs/versionString" },
            "httpx": { "$ref": "#/$defs/versionString" }
          }
        },
        "assertions": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "historical_default_unchanged",
            "installed_from_clean_site_packages",
            "raw_values_persisted",
            "model_packages_imported",
            "torch_imported",
            "transformers_imported",
            "gpu_visible",
            "valid_case_count",
            "invalid_document_count"
          ],
          "properties": {
            "historical_default_unchanged": { "const": true },
            "installed_from_clean_site_packages": { "const": true },
            "raw_values_persisted": { "const": false },
            "model_packages_imported": { "const": false },
            "torch_imported": { "const": false },
            "transformers_imported": { "const": false },
            "gpu_visible": { "const": "" },
            "valid_case_count": { "const": 3 },
            "invalid_document_count": { "const": 1 }
          }
        },
        "isolation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "profile",
            "temporary_venv",
            "source_tree_import_disabled",
            "pip_no_index",
            "pip_no_dependencies",
            "inherited_dependency_environment",
            "bubblewrap_unshare_all",
            "network_namespace_unshared",
            "gpu_devices_hidden",
            "resource_limits_enforced"
          ],
          "properties": {
            "profile": { "const": "bwrap_unshare_all_prlimit_temporary_venv_v1" },
            "temporary_venv": { "const": true },
            "source_tree_import_disabled": { "const": true },
            "pip_no_index": { "const": true },
            "pip_no_dependencies": { "const": true },
            "inherited_dependency_environment": { "const": true },
            "bubblewrap_unshare_all": { "const": true },
            "network_namespace_unshared": { "const": true },
            "gpu_devices_hidden": { "const": true },
            "resource_limits_enforced": { "const": true }
          }
        }
      }
    },
    "public_artifact_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "format",
        "scanner_path",
        "scanner_file_sha256",
        "scanned_file_count",
        "scanned_inventory_sha256",
        "finding_count",
        "finding_kinds"
      ],
      "properties": {
        "status": { "const": "PASS" },
        "format": { "const": "pii_zh_public_artifact_scan_v3" },
        "scanner_path": { "const": "scripts/scan_public_artifacts.py" },
        "scanner_file_sha256": { "$ref": "#/$defs/sha256" },
        "scanned_file_count": { "type": "integer", "minimum": 3 },
        "scanned_inventory_sha256": { "$ref": "#/$defs/sha256" },
        "finding_count": { "const": 0 },
        "finding_kinds": { "const": [] }
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generator_path",
        "generator_file_sha256",
        "schema_path",
        "schema_file_sha256"
      ],
      "properties": {
        "generator_path": {
          "const": "scripts/build_community_v2_github_release_assets_receipt.py"
        },
        "generator_file_sha256": { "$ref": "#/$defs/sha256" },
        "schema_path": {
          "const": "configs/release/community_v2_github_release_assets_receipt.schema.json"
        },
        "schema_file_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "receipt_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "versionString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\\r\\n\\u0000]+$"
    },
    "fileBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_sha256", "size_bytes"],
      "properties": {
        "file_sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "memberBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_sha256", "size_bytes"],
      "properties": {
        "file_sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "namedFileBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "media_type", "file_sha256", "size_bytes"],
      "properties": {
        "name": { "type": "string" },
        "media_type": { "type": "string" },
        "file_sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
