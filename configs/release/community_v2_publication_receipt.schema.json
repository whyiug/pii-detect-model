                "lfs_oid_count",
                "content_verified_count"
              ],
              "properties": {
                "size_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "git_blob_oid_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "lfs_oid_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "content_verified_count": {
                  "type": "integer",
                  "minimum": 0
                }
              }
