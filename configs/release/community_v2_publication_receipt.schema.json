              "type": "integer",
              "minimum": 10
            },
            "inventory_sha256": {
              "$ref": "#/$defs/sha256"
            },
            "files": {
              "type": "object",
              "minProperties": 10,
              "propertyNames": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/hfSafePath"
                  },
                  {
                    "const": ".gitattributes"
                  }
                ]
              },
              "additionalProperties": {
                "$ref": "#/$defs/downloadedFileBinding"
              },
              "required": [
                ".gitattributes",
                "README.md",
                "checksums.txt",
                "model.safetensors",
                "publication_manifest.json"
              ]
            }
